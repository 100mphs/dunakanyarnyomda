---
const services = [
  'Nyomtatás',
  'Fénymásolás',
  'Szkennelés',
  'Spirálozás',
  'Laminálás',
  'Névjegykártya',
  'Szórólap',
  'Poszter',
  'Grafikai tervezés',
  'Egyéb',
];
---

<div
  id="quote-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-slate-950/60 px-4 py-6 opacity-0 backdrop-blur-sm transition-opacity duration-200"
  data-quote-modal
  aria-hidden="true"
>
  <div
    class="max-h-[92vh] w-full max-w-2xl translate-y-4 overflow-y-auto rounded-[2rem] bg-white p-5 shadow-[0_30px_90px_rgba(0,0,0,0.28)] transition-transform duration-200 sm:p-7"
    role="dialog"
    aria-modal="true"
    aria-labelledby="quote-modal-title"
    data-quote-dialog
  >
    <div data-quote-form-state>
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 id="quote-modal-title" class="text-3xl font-extrabold tracking-tight text-[var(--color-ink)]">
            Kérj ajánlatot
          </h2>
          <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">
            Írd meg, mire lenne szükséged, és rövid időn belül felvesszük veled a kapcsolatot.
          </p>
        </div>
        <button
          type="button"
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-slate-200 text-2xl font-bold text-[var(--color-muted)] hover:border-[var(--color-blue)] hover:text-[var(--color-blue)]"
          data-quote-close
          aria-label="Bezárás"
        >
          ×
        </button>
      </div>

      <form class="mt-6 space-y-4" data-quote-form novalidate>
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-extrabold text-[var(--color-ink)]">Név *</span>
            <input
              name="name"
              required
              class="mt-2 min-h-12 w-full rounded-2xl border border-slate-200 px-4 text-sm font-semibold outline-none focus:border-[var(--color-blue)]"
            />
          </label>
          <label class="block">
            <span class="text-sm font-extrabold text-[var(--color-ink)]">Telefon</span>
            <input
              name="phone"
              class="mt-2 min-h-12 w-full rounded-2xl border border-slate-200 px-4 text-sm font-semibold outline-none focus:border-[var(--color-blue)]"
            />
          </label>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-extrabold text-[var(--color-ink)]">E-mail cím *</span>
            <input
              type="email"
              name="email"
              required
              class="mt-2 min-h-12 w-full rounded-2xl border border-slate-200 px-4 text-sm font-semibold outline-none focus:border-[var(--color-blue)]"
            />
          </label>
          <label class="block">
            <span class="text-sm font-extrabold text-[var(--color-ink)]">Szolgáltatás</span>
            <select
              name="service"
              class="mt-2 min-h-12 w-full rounded-2xl border border-slate-200 bg-white px-4 text-sm font-semibold outline-none focus:border-[var(--color-blue)]"
            >
              {services.map((service) => <option value={service}>{service}</option>)}
            </select>
          </label>
        </div>

        <label class="block">
          <span class="text-sm font-extrabold text-[var(--color-ink)]">Üzenet *</span>
          <textarea
            name="message"
            required
            rows="5"
            placeholder={`Például:\n500 db A5 szórólap,\nkétoldalas nyomtatással,\ntervezéssel együtt.`}
            class="mt-2 w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold leading-6 outline-none focus:border-[var(--color-blue)]"
          ></textarea>
        </label>

        <div
          class="rounded-2xl border-2 border-dashed border-slate-200 bg-slate-50 p-4 transition data-[dragging=true]:border-[var(--color-blue)] data-[dragging=true]:bg-[var(--color-blue)]/5"
          data-file-drop
        >
          <label class="flex cursor-pointer flex-col gap-2">
            <span class="text-sm font-extrabold text-[var(--color-ink)]">Fájl csatolása</span>
            <span class="text-sm leading-6 text-[var(--color-muted)]">
              Csatolhatod a nyomtatandó anyagot, logót vagy egyéb dokumentumot. PDF, JPG, JPEG, PNG, DOC, DOCX,
              maximum 20 MB.
            </span>
            <input
              type="file"
              name="files"
              multiple
              accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,application/pdf,image/jpeg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
              class="mt-2 block w-full text-sm text-[var(--color-muted)] file:mr-4 file:rounded-full file:border-0 file:bg-[var(--color-blue)] file:px-4 file:py-2 file:text-sm file:font-extrabold file:text-white"
              data-file-input
            />
          </label>
          <ul class="mt-3 space-y-2 text-sm font-semibold text-[var(--color-ink)]" data-file-list></ul>
          <div class="mt-3 hidden h-2 overflow-hidden rounded-full bg-slate-200" data-upload-progress>
            <span class="block h-full w-0 rounded-full bg-[var(--color-blue)] transition-all"></span>
          </div>
        </div>

        <label class="flex items-start gap-3 rounded-2xl bg-slate-50 p-4">
          <input type="checkbox" name="privacy" required class="mt-1 h-4 w-4 accent-[var(--color-blue)]" />
          <span class="text-sm leading-6 text-[var(--color-muted)]">
            Elfogadom az adatkezelési tájékoztatót.
          </span>
        </label>

        <p class="hidden rounded-2xl bg-red-50 px-4 py-3 text-sm font-bold text-red-700" data-quote-error></p>

        <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
          <button type="button" class="brand-button-secondary w-full sm:w-fit" data-quote-close>Mégse</button>
          <button type="submit" class="brand-button-primary w-full sm:w-fit" data-quote-submit>
            Ajánlatkérés elküldése
          </button>
        </div>
      </form>
    </div>

    <div class="hidden py-8 text-center" data-quote-success>
      <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-green-100 text-4xl text-green-600">
        ✓
      </div>
      <h2 class="mt-6 text-3xl font-extrabold text-[var(--color-ink)]">Köszönjük!</h2>
      <p class="mx-auto mt-3 max-w-md text-base leading-7 text-[var(--color-muted)]">
        Ajánlatkérésed sikeresen megérkezett. Rövid időn belül felvesszük veled a kapcsolatot.
      </p>
      <button type="button" class="brand-button-primary mt-7" data-quote-close>Bezárás</button>
    </div>
  </div>
</div>

<script>
  const modal = document.querySelector<HTMLElement>('[data-quote-modal]');
  const dialog = document.querySelector<HTMLElement>('[data-quote-dialog]');
  const form = document.querySelector<HTMLFormElement>('[data-quote-form]');
  const formState = document.querySelector<HTMLElement>('[data-quote-form-state]');
  const successState = document.querySelector<HTMLElement>('[data-quote-success]');
  const fileInput = document.querySelector<HTMLInputElement>('[data-file-input]');
  const fileDrop = document.querySelector<HTMLElement>('[data-file-drop]');
  const fileList = document.querySelector<HTMLElement>('[data-file-list]');
  const errorBox = document.querySelector<HTMLElement>('[data-quote-error]');
  const submitButton = document.querySelector<HTMLButtonElement>('[data-quote-submit]');
  const progress = document.querySelector<HTMLElement>('[data-upload-progress]');
  const progressBar = progress?.querySelector<HTMLElement>('span');
  let isSubmitting = false;

  const allowedExtensions = ['pdf', 'jpg', 'jpeg', 'png', 'doc', 'docx'];
  const maxFileSize = 20 * 1024 * 1024;

  const showModal = () => {
    if (!modal || !dialog) return;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    modal.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(() => {
      modal.classList.remove('opacity-0');
      dialog.classList.remove('translate-y-4');
    });
    document.documentElement.style.overflow = 'hidden';
    form?.querySelector<HTMLInputElement>('input[name="name"]')?.focus();
  };

  const hideModal = () => {
    if (!modal || !dialog || isSubmitting) return;
    modal.classList.add('opacity-0');
    dialog.classList.add('translate-y-4');
    modal.setAttribute('aria-hidden', 'true');
    document.documentElement.style.overflow = '';
    window.setTimeout(() => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      form?.reset();
      if (fileList) fileList.innerHTML = '';
      if (errorBox) {
        errorBox.hidden = true;
        errorBox.textContent = '';
        errorBox.classList.add('hidden');
      }
      formState?.classList.remove('hidden');
      successState?.classList.add('hidden');
      if (progress) progress.classList.add('hidden');
      if (progressBar) progressBar.style.width = '0%';
    }, 180);
  };

  const updateFileList = () => {
    if (!fileInput || !fileList) return;
    const files = Array.from(fileInput.files ?? []);
    fileList.innerHTML = '';
    files.forEach((file) => {
      const li = document.createElement('li');
      li.textContent = `${file.name} (${Math.round(file.size / 1024)} KB)`;
      fileList.append(li);
    });
  };

  const validateFiles = () => {
    const files = Array.from(fileInput?.files ?? []);
    for (const file of files) {
      const extension = file.name.split('.').pop()?.toLowerCase() ?? '';
      if (!allowedExtensions.includes(extension)) {
        return 'Csak PDF, JPG, JPEG, PNG, DOC vagy DOCX fájl csatolható.';
      }
      if (file.size > maxFileSize) {
        return 'Egy fájl mérete maximum 20 MB lehet.';
      }
    }
    return '';
  };

  const showError = (message: string) => {
    if (!errorBox) return;
    errorBox.textContent = message;
    errorBox.hidden = false;
    errorBox.classList.remove('hidden');
  };

  document.querySelectorAll('[data-quote-open]').forEach((button) => {
    button.addEventListener('click', showModal);
  });

  document.querySelectorAll('[data-quote-close]').forEach((button) => {
    button.addEventListener('click', hideModal);
  });

  modal?.addEventListener('click', (event) => {
    if (event.target === modal) hideModal();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && modal?.getAttribute('aria-hidden') === 'false') hideModal();
  });

  fileInput?.addEventListener('change', updateFileList);

  ['dragenter', 'dragover'].forEach((eventName) => {
    fileDrop?.addEventListener(eventName, (event) => {
      event.preventDefault();
      fileDrop.dataset.dragging = 'true';
    });
  });

  ['dragleave', 'drop'].forEach((eventName) => {
    fileDrop?.addEventListener(eventName, (event) => {
      event.preventDefault();
      fileDrop.dataset.dragging = 'false';
    });
  });

  fileDrop?.addEventListener('drop', (event) => {
    if (!fileInput || !event.dataTransfer?.files.length) return;
    fileInput.files = event.dataTransfer.files;
    updateFileList();
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (isSubmitting || !form || !submitButton) return;

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const fileError = validateFiles();
    if (fileError) {
      showError(fileError);
      return;
    }

    isSubmitting = true;
    submitButton.disabled = true;
    submitButton.textContent = 'Küldés...';
    if (errorBox) errorBox.classList.add('hidden');
    if (progress) progress.classList.remove('hidden');
    if (progressBar) progressBar.style.width = '45%';

    try {
      const response = await fetch('/api/quote', {
        method: 'POST',
        body: new FormData(form),
      });

      if (progressBar) progressBar.style.width = '100%';

      if (!response.ok) {
        const result = await response.json().catch(() => null);
        throw new Error(result?.message || 'Nem sikerült elküldeni az ajánlatkérést.');
      }

      formState?.classList.add('hidden');
      successState?.classList.remove('hidden');
    } catch (error) {
      showError(error instanceof Error ? error.message : 'Váratlan hiba történt.');
    } finally {
      isSubmitting = false;
      submitButton.disabled = false;
      submitButton.textContent = 'Ajánlatkérés elküldése';
    }
  });
</script>
