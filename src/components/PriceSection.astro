---
type Accent =
  | 'print'
  | 'flyer'
  | 'business'
  | 'design'
  | 'poster'
  | 'spiral'
  | 'laminate'
  | 'scan'
  | 'copy';

type PriceRow = {
  label: string;
  values: (number | string)[];
};

type PriceTable = {
  title: string;
  subtitle?: string;
  rowHeader: string;
  columns: string[];
  rows: PriceRow[];
};

const accentMap: Record<Accent, string> = {
  print: '#0B5FFF',
  flyer: '#FF1493',
  business: '#F4C400',
  design: '#111111',
  poster: '#00BCD4',
  spiral: '#7C4DFF',
  laminate: '#00ACC1',
  scan: '#4CAF50',
  copy: '#0B5FFF',
};

const serviceOrder = [
  'nyomtatas',
  'fenymasolas',
  'szkenneles',
  'spiralozas',
  'laminalas',
  'szorolapok',
  'nevjegykartyak',
  'poszterek',
  'grafikai-tervezes',
] as const;

const orderIndex = (id: string) => serviceOrder.indexOf(id as (typeof serviceOrder)[number]);

const printingPapers = [
  {
    id: 'paper-80',
    title: '80 g normál papír',
    sizes: ['A5', 'A4', 'A3'],
    bw: [
      { label: '1-20 oldal', prices: { A5: 40, A4: 50, A3: 100 } },
      { label: '21-100 oldal', prices: { A5: 20, A4: 40, A3: 80 } },
      { label: '101+ oldal', prices: { A5: 15, A4: 30, A3: 60 } },
    ],
    color: [
      { label: '1-20 oldal', prices: { A5: 120, A4: 180, A3: 360 } },
      { label: '21-100 oldal', prices: { A5: 100, A4: 150, A3: 300 } },
      { label: '101+ oldal', prices: { A5: 80, A4: 120, A3: 240 } },
    ],
  },
  {
    id: 'paper-120',
    title: '120 g prémium papír',
    sizes: ['A5', 'A4', 'A3'],
    bw: [
      { label: '1-20 oldal', prices: { A5: 45, A4: 60, A3: 120 } },
      { label: '21-100 oldal', prices: { A5: 35, A4: 50, A3: 100 } },
      { label: '101+ oldal', prices: { A5: 25, A4: 40, A3: 80 } },
    ],
    color: [
      { label: '1-20 oldal', prices: { A5: 150, A4: 220, A3: 440 } },
      { label: '21-100 oldal', prices: { A5: 120, A4: 180, A3: 360 } },
      { label: '101+ oldal', prices: { A5: 100, A4: 150, A3: 300 } },
    ],
  },
  {
    id: 'paper-300',
    title: '300 g karton',
    sizes: ['A5', 'A4', 'A3'],
    bw: [
      { label: '1-20 oldal', prices: { A5: 120, A4: 180, A3: 360 } },
      { label: '21+ oldal', prices: { A5: 100, A4: 150, A3: 300 } },
    ],
    color: [
      { label: '1-20 oldal', prices: { A5: 300, A4: 450, A3: 900 } },
      { label: '21+ oldal', prices: { A5: 250, A4: 400, A3: 800 } },
    ],
  },
];

const accordionItems = [
  {
    id: 'nyomtatas',
    icon: '▣',
    title: 'Nyomtatás',
    summary: '80 g, 120 g és 300 g papír, fekete-fehér vagy színes nyomatok.',
    accent: 'print',
    kind: 'printing',
    search: 'nyomtatás nyomtatas a4 a3 a5 80g 120g 300g fekete fehér színes',
  },
  {
    id: 'szorolapok',
    icon: '▤',
    title: 'Szórólapok',
    summary: '120 g fényes műnyomó papír, standard vagy teljes kifutós kivitel.',
    accent: 'flyer',
    badge: 'Népszerű',
    kind: 'tables',
    search: 'szórólapok szorolap a6 a5 egyoldalas kétoldalas népszerű',
    tables: [
      {
        title: 'Standard - A6',
        subtitle: 'Fehér szegély',
