    <div class="mx-auto mt-10 max-w-5xl rounded-[1.6rem] border border-dashed border-[var(--color-blue)]/35 bg-[linear-gradient(180deg,rgba(16,156,243,0.05),rgba(255,255,255,0.9))] p-5 sm:p-8">
      <div class="overflow-hidden rounded-[1.2rem] border border-slate-200 bg-white">
        <div class="grid grid-cols-[1.1fr_1.4fr_0.8fr_0.8fr] gap-3 bg-[var(--color-ink)] px-4 py-4 text-[11px] font-bold uppercase tracking-[0.2em] text-white sm:text-xs">
