---
import heroProductShowcase from '../assets/hero-product-showcase.png';
import PhoneIcon from './PhoneIcon.astro';

const valueProps = [
  {
    icon: '⚡',
    title: 'Rövid határidők',
    description: 'Gyors és rugalmas kivitelezés',
  },
  {
    icon: '🎨',
    title: 'Egyedi tervezés',
    description: 'Professzionális grafikai tervezés egy helyen',
  },
  {
    icon: '👥',
    title: 'Lakossági és üzleti ügyfeleknek',
    description: 'Kis példányszámtól a nagyobb megrendelésekig',
  },
];
---

<section class="mx-auto grid min-h-[calc(100vh-6.5rem)] w-full max-w-[96rem] items-center px-4 py-8 sm:px-6 lg:px-8 lg:py-10">
  <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] xl:gap-24">
    <div class="max-w-[46rem]">
      <p class="mb-5 text-xs font-extrabold uppercase tracking-[0.34em] text-[var(--color-blue)] sm:text-sm">
        DUNAKANYAR NYOMDA
      </p>
      <h1 class="text-[clamp(3rem,3.7vw,4rem)] font-extrabold leading-[1.05] tracking-tight text-[var(--color-ink)]">
        <span class="block xl:whitespace-nowrap">Nyomtatás gyorsan.</span>
        <span class="block text-[var(--color-pink)] xl:whitespace-nowrap">Profi megjelenés.</span>
      </h1>
      <p class="mt-6 max-w-[42rem] text-base leading-8 text-[var(--color-ink)]/78 sm:text-lg">
        Legyen szó egy dokumentumról, szakdolgozatról vagy több ezer szórólapról, nálunk a
        tervezéstől a kivitelezésig mindent egy helyen intézhetsz. Gyors, megbízható és minőségi
        nyomdai megoldások magánszemélyeknek és vállalkozásoknak.
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <button type="button" class="brand-button-primary" data-quote-open>
          <PhoneIcon class="h-4 w-4 fill-current" />
          Ajánlatot kérek
        </button>
        <a href="#szolgaltatasok" class="brand-button-secondary">
          Mit tudunk nyomtatni?
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="mt-10 grid gap-5 sm:grid-cols-3">
        {valueProps.map((item) => (
          <div class="min-w-0">
            <div class="text-3xl leading-none" aria-hidden="true">{item.icon}</div>
            <h2 class="mt-3 text-sm font-extrabold leading-5 text-[var(--color-ink)]">
              {item.title}
            </h2>
            <p class="mt-2 text-sm leading-6 text-[var(--color-muted)]">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>

    <div class="relative">
      <div class="relative mx-auto max-w-[44rem] overflow-hidden rounded-[2rem] bg-[#fbfbfd] shadow-[0_28px_80px_rgba(16,17,19,0.10)]">
        <img
          src={heroProductShowcase.src}
          alt="Dunakanyar Nyomda nyomdai termékek és arculati anyagok"
          class="h-auto max-h-[calc(100svh-9rem)] w-full object-contain"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
