---
import logo from '../assets/logo.svg';
import { quickLinks } from '../data/site';
import PhoneIcon from './PhoneIcon.astro';
---

<header class="sticky top-0 z-50 border-b border-white/60 bg-white/95 backdrop-blur-xl">
  <div class="section-shell flex min-h-[4.75rem] items-center gap-3 py-2 lg:min-h-0 lg:justify-between lg:gap-4 lg:py-4">
    <button
      type="button"
      class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-slate-200 bg-white text-[var(--color-ink)] shadow-[0_10px_26px_rgba(16,17,19,0.08)] lg:hidden"
      aria-label="Menü megnyitása"
      aria-controls="mobile-menu"
      aria-expanded="false"
      data-mobile-menu-toggle
    >
      <span class="sr-only">Menü</span>
      <span class="relative h-5 w-6" aria-hidden="true">
        <span class="absolute left-0 top-0 h-0.5 w-6 rounded-full bg-current transition duration-200" data-menu-line="top"></span>
        <span class="absolute left-0 top-1/2 h-0.5 w-6 -translate-y-1/2 rounded-full bg-current transition duration-200" data-menu-line="middle"></span>
        <span class="absolute bottom-0 left-0 h-0.5 w-6 rounded-full bg-current transition duration-200" data-menu-line="bottom"></span>
      </span>
    </button>

    <a href="#fooldal" class="min-w-0 shrink" aria-label="Dunakanyar Nyomda" data-mobile-menu-link>
      <img
        src={logo.src}
        alt="Dunakanyar Nyomda"
        class="h-auto max-h-16 w-[13rem] max-w-[calc(100vw-5.75rem)] object-contain sm:w-[13.75rem] lg:w-56 xl:w-64"
      />
    </a>

    <nav class="hidden items-center gap-8 text-sm font-bold uppercase tracking-wide text-[var(--color-ink)] lg:flex">
      {quickLinks.map((link) => (
        <a href={link.href} class="hover:text-[var(--color-blue)]">{link.label}</a>
      ))}
    </nav>

    <button type="button" class="brand-button-primary hidden lg:inline-flex" data-quote-open data-header-quote>
      <PhoneIcon class="h-4 w-4 fill-current" />
      Kérj ajánlatot!
    </button>

  </div>

  <div
    id="mobile-menu"
    class="grid max-h-0 overflow-hidden border-t border-transparent bg-white opacity-0 transition-[max-height,opacity,border-color] duration-300 ease-out lg:hidden"
    data-mobile-menu
    aria-hidden="true"
  >
    <div class="section-shell py-4" data-mobile-menu-panel>
      <nav class="grid gap-1 text-lg font-extrabold text-[var(--color-ink)]">
        {quickLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-2xl px-4 py-3 hover:bg-slate-50 hover:text-[var(--color-blue)]"
            data-mobile-menu-link
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="mt-4 border-t border-slate-200 pt-4">
        <a
          href="tel:+36702110674"
          class="block rounded-2xl bg-slate-50 px-4 py-3 text-lg font-extrabold text-[var(--color-ink)] hover:text-[var(--color-blue)]"
          data-mobile-menu-link
        >
          +36 70 211 0674
        </a>
        <button
          type="button"
          class="brand-button-primary mt-3 w-full"
          data-quote-open
          data-mobile-menu-link
        >
          Ajánlatot kérek
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const panel = document.querySelector<HTMLElement>('[data-mobile-menu-panel]');
  const toggle = document.querySelector<HTMLButtonElement>('[data-mobile-menu-toggle]');
  const topLine = document.querySelector<HTMLElement>('[data-menu-line="top"]');
  const middleLine = document.querySelector<HTMLElement>('[data-menu-line="middle"]');
  const bottomLine = document.querySelector<HTMLElement>('[data-menu-line="bottom"]');
  let lastFocusedElement: Element | null = null;

  const focusableSelector = 'a[href], button:not([disabled])';

  const getFocusableItems = () =>
    Array.from(panel?.querySelectorAll<HTMLElement>(focusableSelector) ?? []).filter(
      (item) => !item.hasAttribute('hidden') && item.tabIndex !== -1,
    );

  const setIconState = (isOpen: boolean) => {
    topLine?.classList.toggle('top-1/2', isOpen);
    topLine?.classList.toggle('-translate-y-1/2', isOpen);
    topLine?.classList.toggle('rotate-45', isOpen);
    middleLine?.classList.toggle('opacity-0', isOpen);
    bottomLine?.classList.toggle('bottom-auto', isOpen);
    bottomLine?.classList.toggle('top-1/2', isOpen);
    bottomLine?.classList.toggle('-translate-y-1/2', isOpen);
    bottomLine?.classList.toggle('-rotate-45', isOpen);
    toggle?.setAttribute('aria-label', isOpen ? 'Menü bezárása' : 'Menü megnyitása');
  };

  const openMenu = () => {
    if (!menu || !panel || !toggle) return;
    lastFocusedElement = document.activeElement;
    menu.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    menu.classList.remove('max-h-0', 'opacity-0', 'border-transparent');
    menu.classList.add('max-h-[32rem]', 'opacity-100', 'border-slate-100');
    setIconState(true);
    getFocusableItems()[0]?.focus();
  };

  const closeMenu = (restoreFocus = true) => {
    if (!menu || !panel || !toggle || toggle.getAttribute('aria-expanded') !== 'true') return;
    menu.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    menu.classList.add('max-h-0', 'opacity-0', 'border-transparent');
    menu.classList.remove('max-h-[32rem]', 'opacity-100', 'border-slate-100');
    setIconState(false);
    if (restoreFocus && lastFocusedElement instanceof HTMLElement) lastFocusedElement.focus();
  };

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    if (isOpen) closeMenu();
    else openMenu();
  });

  document.addEventListener('click', (event) => {
    if (toggle?.getAttribute('aria-expanded') !== 'true') return;
    const target = event.target;
    if (!(target instanceof Node)) return;
    if (menu?.contains(target) || toggle?.contains(target)) return;
    closeMenu(false);
  });

  document.querySelectorAll('[data-mobile-menu-link]').forEach((item) => {
    item.addEventListener('click', () => closeMenu(false));
  });

  document.addEventListener('keydown', (event) => {
    if (!menu || toggle?.getAttribute('aria-expanded') !== 'true') return;

    if (event.key === 'Escape') {
      closeMenu();
      return;
    }

    if (event.key !== 'Tab') return;

    const focusableItems = getFocusableItems();
    const firstItem = focusableItems[0];
    const lastItem = focusableItems[focusableItems.length - 1];
    if (!firstItem || !lastItem) return;

    if (event.shiftKey && document.activeElement === firstItem) {
      event.preventDefault();
      lastItem.focus();
    } else if (!event.shiftKey && document.activeElement === lastItem) {
      event.preventDefault();
      firstItem.focus();
    }
  });
</script>
