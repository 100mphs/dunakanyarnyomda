---
import aboutPrinter from '../assets/about-printer-closeup.png';

const features = [
  {
    icon: '◷',
    title: 'Gyors kivitelezés',
    description: 'Rövid átfutási idő, tervezhetőség és pontos kommunikáció.',
    color: 'var(--color-pink)',
    bg: 'rgba(230,0,126,0.1)',
  },
  {
    icon: '☆',
    title: 'Prémium minőség',
    description: 'Modern géppark, kiváló alapanyagok és ellenőrzött nyomdai folyamatok.',
    color: 'var(--color-yellow)',
    bg: 'rgba(255,207,15,0.16)',
  },
  {
    icon: '♢',
    title: 'Megbízható partner',
    description: 'Egyedi igényekre szabott ajánlatokkal és hosszú távú szemlélettel segítünk.',
    color: 'var(--color-blue)',
    bg: 'rgba(16,156,243,0.11)',
  },
];
---

<section id="rolunk" class="section-shell pt-20">
  <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_22px_70px_rgba(16,17,19,0.08)]">
    <div class="grid gap-0 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1fr)] xl:grid-cols-[minmax(0,0.86fr)_minmax(0,1fr)_minmax(20rem,0.95fr)]">
      <div class="min-h-[22rem] overflow-hidden lg:min-h-full">
        <img
          src={aboutPrinter.src}
          alt="Professzionális nyomtató színes nyomtatás közben"
          class="h-full min-h-[22rem] w-full object-cover"
          loading="lazy"
        />
      </div>

      <div class="flex flex-col justify-center px-6 py-8 sm:px-8 lg:py-12">
        <p class="text-sm font-extrabold uppercase tracking-[0.24em] text-[var(--color-blue)]">
          Rólunk
        </p>
        <h2 class="mt-4 text-3xl font-extrabold leading-tight tracking-tight text-[var(--color-ink)] sm:text-4xl">
          Helyi nyomda.
          <span class="block">Gyors megoldások.</span>
        </h2>
        <p class="mt-6 text-sm leading-8 text-[var(--color-ink)]/78 sm:text-base">
          A Dunakanyar Nyomda Tahitótfaluban segíti a lakossági és üzleti ügyfeleket dokumentumok,
          reklámanyagok és egyedi nyomdai termékek elkészítésében. Kis példányszámtól a nagyobb
          megrendelésekig gyors és megbízható megoldásokat kínálunk.
        </p>
        <a href="#kapcsolat" class="brand-button-primary mt-8 w-full sm:w-fit">
          Tovább a kapcsolat részhez
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="grid gap-4 bg-slate-50/55 px-6 pb-8 sm:px-8 lg:py-8 xl:bg-white">
        {features.map((feature) => (
          <article class="flex items-start gap-4 rounded-[1.4rem] border border-slate-200 bg-white p-5 shadow-[0_12px_35px_rgba(16,17,19,0.06)]">
            <div
              class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl text-3xl font-extrabold"
              style={`background:${feature.bg}; color:${feature.color};`}
              aria-hidden="true"
            >
              {feature.icon}
            </div>
            <div>
              <h3 class="text-base font-extrabold uppercase tracking-tight text-[var(--color-ink)]">
                {feature.title}
              </h3>
              <p class="mt-2 text-sm leading-6 text-[var(--color-muted)]">{feature.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
