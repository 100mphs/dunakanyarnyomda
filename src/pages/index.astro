---
import logo from '../assets/logo.svg';
import map from '../assets/map.svg';
import iconPrint from '../assets/icons_print.svg';
import iconFlyer from '../assets/icons_flyer.svg';
import iconBusinessCard from '../assets/icons_business_card.svg';
import iconGraphicDesign from '../assets/icons_graphic_design.svg';
import iconPoster from '../assets/icons_poster.svg';
import '../styles/global.css';

const services = [
  {
    title: 'Nyomtatás',
    description: 'Digitális és nagyformátumú nyomtatás gyors kivitelezéssel.',
    icon: iconPrint,
  },
  {
    title: 'Szórólapok',
    description: 'Plakátok, prospektusok és szóróanyagok többféle méretben.',
    icon: iconFlyer,
  },
  {
    title: 'Névjegykártyák',
    description: 'Prémium papírok, igényes felületek és rövid határidők.',
    icon: iconBusinessCard,
  },
  {
    title: 'Grafikai tervezés',
    description: 'Logó, arculat, kiadvány és nyomdai előkészítés egy helyen.',
    icon: iconGraphicDesign,
  },
  {
    title: 'Poszterek',
    description: 'Molinók, táblák, roll-upok és egyedi látványanyagok.',
    icon: iconPoster,
  },
];

const highlights = [
  {
    title: 'Gyors határidő',
    description: 'Rövid átfutási idővel, tervezhetően és pontos kommunikációval dolgozunk.',
    accent: 'var(--color-pink)',
  },
  {
    title: 'Prémium minőség',
    description: 'Modern géppark, kiváló alapanyagok és ellenőrzött nyomdai folyamatok.',
    accent: 'var(--color-yellow)',
  },
  {
    title: 'Megbízható partner',
    description: 'Egyedi igényekre szabott ajánlatokkal és hosszú távú szemlélettel segítünk.',
    accent: 'var(--color-blue)',
  },
];

const quickLinks = [
  { label: 'Főoldal', href: '#fooldal' },
  { label: 'Szolgáltatások', href: '#szolgaltatasok' },
  { label: 'Árlista', href: '#arlista' },
  { label: 'Rólunk', href: '#rolunk' },
  { label: 'Kapcsolat', href: '#kapcsolat' },
];

const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="hu">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Digitális és hagyományos nyomtatás, grafikai tervezés és teljes körű nyomdai megoldások Tahitótfaluban."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Dunakanyar Nyomda</title>
  </head>
  <body>
    <header class="sticky top-0 z-50 border-b border-white/60 bg-white/88 backdrop-blur-xl">
      <div class="section-shell flex flex-wrap items-center justify-between gap-5 py-4">
        <a href="#fooldal" class="shrink-0" aria-label="Dunakanyar Nyomda">
          <img src={logo.src} alt="Dunakanyar Nyomda" class="h-auto w-56 sm:w-64" />
        </a>

        <nav class="hidden items-center gap-8 text-sm font-bold uppercase tracking-wide text-[var(--color-ink)] lg:flex">
          {quickLinks.map((link) => (
            <a href={link.href} class="hover:text-[var(--color-blue)]">{link.label}</a>
          ))}
        </nav>

        <a href="#kapcsolat" class="brand-button-primary">
          <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
            <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.11.37 2.3.56 3.52.56a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.85 21 3 13.15 3 3.99a1 1 0 0 1 1-1H7.5a1 1 0 0 1 1 1c0 1.22.19 2.41.56 3.52a1 1 0 0 1-.24 1.02l-2.2 2.26Z" />
          </svg>
          Kérj ajánlatot!
        </a>

        <nav class="flex w-full flex-wrap items-center justify-center gap-x-5 gap-y-3 border-t border-slate-100 pt-4 text-xs font-bold uppercase tracking-wide text-[var(--color-ink)] lg:hidden">
          {quickLinks.map((link) => (
            <a href={link.href} class="hover:text-[var(--color-blue)]">{link.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main id="fooldal">
      <section class="section-shell pt-12 md:pt-16">
        <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
          <div class="max-w-xl">
            <p class="mb-5 text-sm font-extrabold uppercase tracking-[0.24em] text-[var(--color-blue)]">
              Minőség, amire
            </p>
            <h1 class="text-5xl font-extrabold uppercase leading-[0.92] tracking-tight text-[var(--color-ink)] sm:text-6xl md:text-7xl">
              Szükséged
              <span class="mt-3 block text-[var(--color-pink)]">van</span>
            </h1>
            <p class="mt-7 max-w-lg text-base leading-8 text-[var(--color-muted)] sm:text-lg">
              Digitális és hagyományos nyomtatás, grafikai tervezés és teljes körű nyomdai
              megoldások gyorsan, megbízhatóan, prémium kivitelezéssel.
            </p>

            <div class="mt-9 flex flex-wrap gap-4">
              <a href="#kapcsolat" class="brand-button-primary">
                <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
                  <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.11.37 2.3.56 3.52.56a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.85 21 3 13.15 3 3.99a1 1 0 0 1 1-1H7.5a1 1 0 0 1 1 1c0 1.22.19 2.41.56 3.52a1 1 0 0 1-.24 1.02l-2.2 2.26Z" />
                </svg>
                Kérj ajánlatot!
              </a>
              <a href="#szolgaltatasok" class="brand-button-secondary">Szolgáltatások</a>
            </div>
          </div>

          <div class="relative">
            <div class="surface-card relative overflow-hidden px-6 pb-0 pt-8 sm:px-10 sm:pt-10">
              <div class="absolute inset-x-0 top-0 h-56 bg-[radial-gradient(circle_at_top_right,_rgba(16,156,243,0.2),_transparent_55%)]"></div>
              <div class="relative mx-auto flex max-w-[34rem] justify-center">
                <div class="absolute top-1/2 h-[22rem] w-[22rem] -translate-y-1/2 rounded-full border-[12px] border-[var(--color-blue)] bg-[linear-gradient(180deg,#7dd4ff_0%,#e7f7ff_100%)] sm:h-[30rem] sm:w-[30rem]"></div>
                <div class="relative mt-12 flex h-[27rem] w-full max-w-[28rem] items-end justify-center sm:h-[33rem]">
                  <div class="absolute bottom-0 h-44 w-5 rounded-full bg-[#16181d] shadow-2xl sm:h-52"></div>
                  <div class="absolute bottom-28 h-5 w-16 rounded-full bg-[#252830] blur-sm"></div>

                  <div class="relative z-10 w-[85%] -rotate-[10deg] rounded-[2.25rem] border border-white/10 bg-[linear-gradient(145deg,#050608_0%,#11141b_42%,#2b2f38_100%)] p-5 shadow-[0_35px_55px_rgba(0,0,0,0.35)] sm:p-7">
                    <div class="rounded-[1.6rem] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.05),rgba(255,255,255,0.01))] px-5 py-7">
                      <p class="text-lg font-extrabold uppercase tracking-[0.14em] text-white/95 sm:text-2xl">
                        DUNAKANYAR
                      </p>
                      <p class="mt-2 text-3xl font-extrabold uppercase tracking-tight text-white sm:text-5xl">
                        NYOMDA
                      </p>
                      <div class="brand-stripes mt-8">
                        <span></span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="hero-wave mt-3 sm:mt-0">
                <span></span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="szolgaltatasok" class="section-shell pt-20">
        <h2 class="section-title">Szolgáltatásaink</h2>
        <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-5">
          {services.map((service) => (
            <article class="service-card">
              <img
                src={service.icon.src}
                alt=""
                aria-hidden="true"
                class="relative mx-auto h-20 w-20 object-contain"
              />
              <h3 class="relative mt-6 text-xl font-extrabold uppercase tracking-tight">
                {service.title}
              </h3>
              <p class="relative mt-3 text-sm leading-7 text-[var(--color-muted)]">
                {service.description}
              </p>
            </article>
          ))}
        </div>
      </section>

      <section id="arlista" class="section-shell pt-20">
        <div class="surface-card px-6 py-8 sm:px-10 sm:py-10">
          <h2 class="section-title">Árlista</h2>
          <div class="mx-auto mt-10 max-w-5xl rounded-[1.6rem] border border-dashed border-[var(--color-blue)]/35 bg-[linear-gradient(180deg,rgba(16,156,243,0.05),rgba(255,255,255,0.9))] p-5 sm:p-8">
            <div class="overflow-hidden rounded-[1.2rem] border border-slate-200 bg-white">
              <div class="grid grid-cols-[1.1fr_1.4fr_0.8fr_0.8fr] gap-3 bg-[var(--color-ink)] px-4 py-4 text-[11px] font-bold uppercase tracking-[0.2em] text-white sm:text-xs">
                <span>Termék</span>
                <span>Leírás</span>
                <span>Mennyiség</span>
                <span>Ár</span>
              </div>
              <div class="space-y-3 px-4 py-5">
                {Array.from({ length: 5 }).map(() => (
                  <div class="grid grid-cols-[1.1fr_1.4fr_0.8fr_0.8fr] gap-3">
                    <div class="price-placeholder-line"></div>
                    <div class="price-placeholder-line"></div>
                    <div class="price-placeholder-line"></div>
                    <div class="price-placeholder-line"></div>
                  </div>
                ))}
              </div>
            </div>

            <div class="mt-6 text-center">
              <p class="text-base font-semibold text-[var(--color-ink)]">
                Az árlista helyére később érkezik a végleges tartalom.
              </p>
              <p class="mx-auto mt-2 max-w-2xl text-sm leading-7 text-[var(--color-muted)]">
                Addig egyedi ajánlat alapján dolgozunk. Küldd el az elképzelést, a méretet, a
                darabszámot és a határidőt, és gyorsan visszajelzünk.
              </p>
              <a href="#kapcsolat" class="brand-button-primary mt-6">Kérj egyedi ajánlatot!</a>
            </div>
          </div>
        </div>
      </section>

      <section id="rolunk" class="section-shell pt-20">
        <div class="grid gap-6 xl:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
          <div class="surface-card overflow-hidden">
            <div class="grid gap-0 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.1fr)]">
              <div class="about-visual relative min-h-[20rem] overflow-hidden"></div>
              <div class="px-6 py-8 sm:px-8 sm:py-10">
                <p class="text-sm font-extrabold uppercase tracking-[0.24em] text-[var(--color-blue)]">
                  Rólunk
                </p>
                <h2 class="mt-4 text-3xl font-extrabold uppercase tracking-tight">Nyomdai partner, aki érti a tempót</h2>
                <p class="mt-5 text-sm leading-7 text-[var(--color-muted)] sm:text-base">
                  A Dunakanyar Nyomda célja, hogy ügyfeleink számára magas minőségű, gyors és
                  rugalmas nyomdai megoldásokat nyújtsunk. Legyen szó kis példányszámú
                  nyomtatásról, grafikai előkészítésről vagy nagyobb volumenű megrendelésről,
                  nálunk jó helyen jár.
                </p>
                <a href="#kapcsolat" class="brand-button-primary mt-8">Tovább a kapcsolat részhez</a>
              </div>
            </div>
          </div>

          <div class="space-y-4">
            {highlights.map((item) => (
              <article class="surface-card flex items-start gap-4 px-5 py-5 sm:px-6">
                <div
                  class="mt-1 flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border bg-white"
                  style={`border-color:${item.accent}; color:${item.accent};`}
                >
                  <svg viewBox="0 0 24 24" class="h-6 w-6 fill-current" aria-hidden="true">
                    <path d="M12 2a10 10 0 1 0 .01 20.01A10 10 0 0 0 12 2Zm1 5v4.59l2.7 2.7-1.4 1.41L11 12.41V7h2Z" />
                  </svg>
                </div>
                <div>
                  <h3 class="text-lg font-extrabold uppercase tracking-tight">{item.title}</h3>
                  <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">{item.description}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="kapcsolat" class="section-shell pb-16 pt-20">
        <div class="surface-card contact-map overflow-hidden">
          <div class="grid items-stretch gap-0 xl:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)]">
            <div class="contact-panel flex flex-col justify-center px-6 py-8 text-white sm:px-8 sm:py-10">
              <p class="text-4xl font-extrabold uppercase leading-tight sm:text-5xl">
                Minden, amire
                <span class="block text-[var(--color-pink)]">szükséged van</span>
              </p>
              <div class="mt-8 space-y-4 text-base">
                <a href="tel:+36301234567" class="flex items-center gap-4 hover:text-[var(--color-blue)]">
                  <span class="flex h-12 w-12 items-center justify-center rounded-full bg-[var(--color-blue)] text-white">
                    <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
                      <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.11.37 2.3.56 3.52.56a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.85 21 3 13.15 3 3.99a1 1 0 0 1 1-1H7.5a1 1 0 0 1 1 1c0 1.22.19 2.41.56 3.52a1 1 0 0 1-.24 1.02l-2.2 2.26Z" />
                    </svg>
                  </span>
                  <span>
                    <span class="block text-lg font-bold uppercase tracking-wide">Kérj ajánlatot!</span>
                    <span class="block text-white/80">+36 30 123 4567</span>
                  </span>
                </a>
                <a href="mailto:info@dunakanyarnyomda.hu" class="block text-white/80 hover:text-white">
                  info@dunakanyarnyomda.hu
                </a>
              </div>
            </div>

            <div class="relative min-h-[20rem]">
              <img
                src={map.src}
                alt="Térkép Tahitótfalu, Klapka utca környékéről"
                class="h-full w-full object-cover"
              />
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="border-t border-slate-200 bg-white">
      <div class="section-shell grid gap-10 py-10 md:grid-cols-2 xl:grid-cols-[minmax(0,1.1fr)_repeat(3,minmax(0,0.63fr))]">
        <div>
          <img src={logo.src} alt="Dunakanyar Nyomda" class="h-auto w-56" />
          <p class="mt-4 max-w-sm text-sm leading-7 text-[var(--color-muted)]">
            Digitális és hagyományos nyomtatás, grafikai tervezés és teljes körű nyomdai
            megoldások a Dunakanyarban.
          </p>
        </div>

        <div>
          <h2 class="text-sm font-extrabold uppercase tracking-[0.22em] text-[var(--color-ink)]">
            Gyors linkek
          </h2>
          <ul class="mt-4 space-y-3 text-sm text-[var(--color-muted)]">
            {quickLinks.map((link) => (
              <li>
                <a href={link.href} class="hover:text-[var(--color-blue)]">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h2 class="text-sm font-extrabold uppercase tracking-[0.22em] text-[var(--color-ink)]">
            Elérhetőség
          </h2>
          <div class="mt-4 space-y-3 text-sm text-[var(--color-muted)]">
            <a href="tel:+36301234567" class="block hover:text-[var(--color-blue)]">+36 30 123 4567</a>
            <a href="mailto:info@dunakanyarnyomda.hu" class="block hover:text-[var(--color-blue)]">
              info@dunakanyarnyomda.hu
            </a>
            <p>2022 Tahitótfalu, Klapka u.</p>
          </div>
        </div>

        <div>
          <h2 class="text-sm font-extrabold uppercase tracking-[0.22em] text-[var(--color-ink)]">
            Kövess minket
          </h2>
          <div class="mt-4">
            <a
              href="https://facebook.com"
              target="_blank"
              rel="noreferrer"
              class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-[var(--color-blue)] text-xl font-extrabold text-white hover:-translate-y-0.5 hover:bg-[var(--color-blue-dark)]"
              aria-label="Facebook"
            >
              f
            </a>
          </div>
        </div>
      </div>

      <div class="bg-[var(--color-blue)] py-4 text-center text-sm text-white">
        © {currentYear} Dunakanyar Nyomda - Minden jog fenntartva.
      </div>
    </footer>
  </body>
</html>
